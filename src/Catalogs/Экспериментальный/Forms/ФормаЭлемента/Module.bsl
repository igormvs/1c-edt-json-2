&НаКлиенте
Процедура Сообщение(Команда)            
	Если Объект.Число = 1 Тогда
		Сообщить("Привет, Пользователь");
	Иначе
		Сообщить("Пока");
	КонецЕсли;
КонецПроцедуры  

&НаКлиенте
Процедура ПоказатьСкрытьПриИзменении(Элемент)
	Если Объект.ПоказатьСкрыть = Истина Тогда
		Элементы.Группа1.Видимость = Истина;
	Иначе
		Элементы.Группа1.Видимость = Ложь;
	КонецЕсли;
КонецПроцедуры
