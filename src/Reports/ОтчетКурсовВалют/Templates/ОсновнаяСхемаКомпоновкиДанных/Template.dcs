			<role>
				<dcscom:dimension>true</dcscom:dimension>
			</role>
		</field>
		<dataSource>ИсточникДанных1</dataSource>
		<query>ВЫБРАТЬ
	КурсыВалют.Период КАК Период,
	КурсыВалют.НазваниеВалюты КАК НазваниеВалюты,
	КурсыВалют.КурсВалюты КАК КурсВалюты
ИЗ
	РегистрСведений.КурсыВалют КАК КурсыВалют</query>
	</dataSet>
	<totalField>
		<dataPath>КурсВалюты</dataPath>
		<expression>Сумма(КурсВалюты)</expression>
	</totalField>
