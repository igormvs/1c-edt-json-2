
&НаКлиенте
Процедура УходТовараЦенаПриИзменении(Элемент)  
	РассчитатьСумма();	
КонецПроцедуры    

&НаКлиенте
Процедура УходТовараКоличествоПриИзменении(Элемент)
	РассчитатьСумма();
КонецПроцедуры                

&НаКлиенте
Процедура РассчитатьСумма()
	Строка = Элементы.УходТовара.ТекущиеДанные;
	Строка.Сумма = Строка.Количество * Строка.Цена;
КонецПроцедуры


