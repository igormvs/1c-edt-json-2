//считаем итоговый результат двух чисел
&НаКлиенте
Процедура Равно(Команда)
	Если Операция = "Сложение" Тогда
		Табло = Буфер + Табло;
	ИначеЕсли Операция = "Вычитание" Тогда
		Табло = Буфер - Табло;
	ИначеЕсли Операция = "Умножение" Тогда
		Табло = Буфер * Табло;	
	ИначеЕсли Операция = "Деление" Тогда
		Табло = Буфер / Табло;	
	ИначеЕсли Операция = "Степень" Тогда
		Табло = Pow(Буфер,Табло);  
	КонецЕсли;
		
КонецПроцедуры


//мгновенные процедуры, считает только одно число
