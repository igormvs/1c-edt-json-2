&НаСервере
Процедура JSONНаСервере()
 
    // Разбиваем текст запросов на отдельные команды (разделитель ";")
    МассивЗапросов = СтрРазделить(Запросы, ";", Ложь);
    
    // Массив для сбора всех данных из всех запросов
    ИтоговыйМассив = Новый Массив;
    
    Для Каждого ТекстЗапроса Из МассивЗапросов Цикл
        ТекстЗапроса = СокрЛП(ТекстЗапроса);
        Если ПустаяСтрока(ТекстЗапроса) Тогда
            Продолжить;
        КонецЕсли;
        
        Запрос = Новый Запрос;
        Запрос.Текст = ТекстЗапроса;
        
        Попытка
            РезультатЗапроса = Запрос.Выполнить();
            ТаблицаРезультата = РезультатЗапроса.Выгрузить();
            
            // Преобразуем таблицу значений в массив структур для JSON
            МассивСтрок = Новый Массив;
            Для Каждого СтрокаТаблицы Из ТаблицаРезультата Цикл
                СтруктураСтроки = Новый Структура;
                Для Каждого Колонка Из ТаблицаРезультата.Колонки Цикл
                    ИмяКолонки = Колонка.Имя;
                    СтруктураСтроки.Вставить(ИмяКолонки, СтрокаТаблицы[ИмяКолонки]);
                КонецЦикла;
                МассивСтрок.Добавить(СтруктураСтроки);
            КонецЦикла;
            
            // Добавляем результат текущего запроса в общий массив
            ИтоговыйМассив.Добавить(МассивСтрок);
            
        Исключение
            // Обработка ошибки выполнения запроса (по желанию)
            Сообщить("Ошибка выполнения запроса: " + ТекстЗапроса + Символы.ПС + ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
        КонецПопытки;
        
    КонецЦикла;
    
    // Запись итогового массива в JSON-файл
    Запись = Новый ЗаписьJSON;
    ПараметрыЗаписи = Новый ПараметрыЗаписиJSON(, Символы.Таб); // отступы табуляцией
    Запись.ОткрытьФайл("C:\файлы\для учёбы\Маг курс 1 сем 2\1с\лаб 5\1.json", "UTF-8", , ПараметрыЗаписи);
    
    // Сериализуем массив массивов структур в JSON
    СериализаторXDTO.ЗаписатьJSON(Запись, ИтоговыйМассив);
    
    Запись.Закрыть();
    
КонецПроцедуры

